# =============================================================================
# FCC_001 - Template de configuration pour Docker
# Copier ce fichier vers .env : cp .env.example .env
# Puis modifier les valeurs selon votre environnement
# =============================================================================

# === BASE DE DONNÉES (utilisé par docker-compose) ===
DB_ROOT_PASSWORD=rootpassword
DB_NAME=fcc_001_db
DB_USER=fcc_user
DB_PASSWORD=fcc_password
DB_PORT_EXTERNAL=3307

# === APPLICATION ===
SECRET_KEY=changez-moi-en-production-avec-une-cle-secrete-longue
APP_NAME=FCC_001 - Atención al Cliente
APP_VERSION=1.0.0

# === INITIALISATION ===
# Créer des données exemple si la base est vide (désactiver en production)
INIT_SAMPLE_DATA=true

# === SERVEUR ===
APP_PORT=8089
LOG_LEVEL=INFO
WEASYPRINT_AVAILABLE=true

# === GUNICORN ===
WORKERS=4
TIMEOUT=120
KEEPALIVE=2

# === NGINX (si profil with-nginx) ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
