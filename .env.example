# =============================================================================
# FCC_001 - Template de configuration pour Docker
# Copier ce fichier vers .env : cp .env.example .env
# Puis remplacer chaque valeur marquée CHANGE_ME par une valeur réelle.
# NE JAMAIS commit le fichier .env (déjà couvert par .gitignore).
# =============================================================================

# === BASE DE DONNÉES (utilisé par docker-compose) ===
DB_ROOT_PASSWORD=CHANGE_ME_root_strong_password
DB_NAME=fcc_001_db
DB_USER=fcc_user
DB_PASSWORD=CHANGE_ME_db_strong_password
DB_PORT_EXTERNAL=3307

# === APPLICATION ===
# Générer avec : openssl rand -hex 32
# En production, l'application DOIT démarrer avec une SECRET_KEY unique.
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
APP_NAME=FCC_001 - Atención al Cliente
APP_VERSION=1.0.0

# === INITIALISATION ===
# Créer des données exemple si la base est vide (désactiver en production)
INIT_SAMPLE_DATA=true

# === SERVEUR ===
APP_PORT=8089
LOG_LEVEL=INFO
WEASYPRINT_AVAILABLE=true

# === SÉCURITÉ ===
# Activer impérativement en production (cookies envoyés uniquement via HTTPS)
SESSION_COOKIE_SECURE=true
# Limite anti-DoS sur la taille d'une requête (en octets, défaut 16 Mo)
MAX_CONTENT_LENGTH=16777216

# === GUNICORN ===
WORKERS=4
TIMEOUT=120
KEEPALIVE=2

# === NGINX (si profil with-nginx) ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
